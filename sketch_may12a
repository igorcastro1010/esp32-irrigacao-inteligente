)rawliteral";


void atualizarSolo() {
  int leitura = analogRead(SOLO_SENSOR_PIN);

  bufferSolo[bufferIndex] = leitura;
  bufferIndex = (bufferIndex + 1) % N_LEITURAS;

  if (totalLeituras < N_LEITURAS) {
    totalLeituras++;
  }

  long soma = 0;

  for (int i = 0; i < totalLeituras; i++) {
    soma += bufferSolo[i];
  }

  int media = soma / totalLeituras;

  umidadeSoloAtual = map(media, SENSOR_SECO, SENSOR_MOLHADO, 0, 100);
  umidadeSoloAtual = constrain(umidadeSoloAtual, 0, 100);
}


void controleIrrigacao() {
  if (!estadoBomba && umidadeSoloAtual <= umidadeLiga) {
    digitalWrite(BOMBA_RELE_PIN, LOW);
    estadoBomba = true;

    Serial.println("Bomba LIGADA");
  }

  if (estadoBomba && umidadeSoloAtual >= umidadeDesliga) {
    digitalWrite(BOMBA_RELE_PIN, HIGH);
    estadoBomba = false;

    Serial.println("Bomba DESLIGADA");
  }
}


void handleRoot() {
  server.send_P(200, "text/html", pagina);
}

void handleDados() {
  String json = "{";
  json += "\"umidade\":" + String(umidadeSoloAtual) + ",";
  json += "\"bomba\":" + String(estadoBomba ? 1 : 0) + ",";
  json += "\"liga\":" + String(umidadeLiga, 0) + ",";
  json += "\"desliga\":" + String(umidadeDesliga, 0);
  json += "}";

  server.send(200, "application/json", json);
}

void handleSet() {
  if (server.hasArg("liga")) {
    umidadeLiga = server.arg("liga").toFloat();
  }

  if (server.hasArg("desliga")) {
    umidadeDesliga = server.arg("desliga").toFloat();
  }

  server.send(200, "text/plain", "OK");
}


void setup() {
  Serial.begin(115200);

  pinMode(BOMBA_RELE_PIN, OUTPUT);
  digitalWrite(BOMBA_RELE_PIN, HIGH);

  WiFi.begin(ssid, password);

  Serial.print("Conectando ao WiFi");

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println();
  Serial.println("WiFi conectado!");
  Serial.print("IP: ");
  Serial.println(WiFi.localIP());

  server.on("/", handleRoot);
  server.on("/dados", handleDados);
  server.on("/set", handleSet);

  server.begin();

  Serial.println("Servidor iniciado!");
}


void loop() {
  server.handleClient();

  unsigned long agora = millis();

  if (agora - tempoAnterior >= intervaloLeitura) {
    tempoAnterior = agora;

    atualizarSolo();
    controleIrrigacao();

    Serial.print("Umidade: ");
    Serial.print(umidadeSoloAtual);
    Serial.print("% | Bomba: ");
    Serial.println(estadoBomba ? "LIGADA" : "DESLIGADA");
  }
}
