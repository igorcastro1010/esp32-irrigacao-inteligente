#include <WiFi.h>
#include <WebServer.h>


const char* ssid = "TP-Link_3480";
const char* password = "SUA_SENHA_AQUI";

#define BOMBA_RELE_PIN 14
#define SOLO_SENSOR_PIN 34


const int SENSOR_SECO = 4095;
const int SENSOR_MOLHADO = 1800;


float umidadeLiga = 40.0;
float umidadeDesliga = 50.0;


const int N_LEITURAS = 10;
int bufferSolo[N_LEITURAS] = {0};
int bufferIndex = 0;
int totalLeituras = 0;


WebServer server(80);

int umidadeSoloAtual = 0;
bool estadoBomba = false;

unsigned long tempoAnterior = 0;
const unsigned long intervaloLeitura = 1000;


const char pagina[] PROGMEM = R"rawliteral(
<!DOCTYPE html>
